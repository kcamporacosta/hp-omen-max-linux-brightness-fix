#!/usr/bin/env bash
set -euo pipefail

# Mirrors the OS-visible brightness slider to the real HP OMEN Max panel
# brightness register discovered during ACPI reverse engineering.

MIN="${OMEN_BACKLIGHT_MIN:-5}"
MAX="${OMEN_BACKLIGHT_MAX:-100}"
POLL_INTERVAL="${OMEN_BACKLIGHT_POLL_INTERVAL:-0.10}"
SOURCE="${OMEN_BACKLIGHT_SOURCE:-}"
BRIGHTNESS_CMD="${OMEN_BRIGHTNESS_CMD:-/usr/local/bin/omen-brightness}"

log() { echo "omen-backlight-sync: $*"; }
err() { echo "omen-backlight-sync: $*" >&2; }

choose_source() {
  if [[ -n "$SOURCE" ]]; then
    echo "$SOURCE"
    return
  fi

  for dev in \
    /sys/class/backlight/acpi_video0 \
    /sys/class/backlight/acpi_video1 \
    /sys/class/backlight/nvidia_wmi_ec_backlight \
    /sys/class/backlight/intel_backlight; do
    if [[ -r "$dev/brightness" && -r "$dev/max_brightness" ]]; then
      echo "$dev"
      return
    fi
  done

  return 1
}

if [[ ! -x "$BRIGHTNESS_CMD" ]]; then
  err "brightness command not found: $BRIGHTNESS_CMD"
  exit 1
fi

BACKLIGHT="$(choose_source)" || {
  err "no usable /sys/class/backlight source found"
  exit 1
}

if [[ ! -r "$BACKLIGHT/brightness" || ! -r "$BACKLIGHT/max_brightness" ]]; then
  err "invalid backlight source: $BACKLIGHT"
  exit 1
fi

log "source=$BACKLIGHT range=$MIN-$MAX poll=${POLL_INTERVAL}s"

last=""
while true; do
  cur="$(cat "$BACKLIGHT/brightness")"
  max="$(cat "$BACKLIGHT/max_brightness")"

  if [[ "$cur" != "$last" && "$cur" =~ ^[0-9]+$ && "$max" =~ ^[0-9]+$ && "$max" -gt 0 ]]; then
    percent=$(( cur * 100 / max ))

    (( percent < MIN )) && percent=$MIN
    (( percent > MAX )) && percent=$MAX

    "$BRIGHTNESS_CMD" "$percent" >/dev/null || err "failed to set real brightness to $percent"
    last="$cur"
  fi

  sleep "$POLL_INTERVAL"
done
