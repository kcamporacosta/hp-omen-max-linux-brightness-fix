#!/usr/bin/env bash
set -u

VERSION="v0.3.0-safe-dev1"

read_file() {
  local file="$1"
  if [[ -r "$file" ]]; then
    cat "$file"
  else
    echo "unknown"
  fi
}

echo "# HP OMEN Max brightness diagnostic report"
echo "Diagnostic version: $VERSION"
echo "Generated: $(date --iso-8601=seconds)"
echo

echo "## System"
echo "Manufacturer:     $(read_file /sys/class/dmi/id/sys_vendor)"
echo "Product name:     $(read_file /sys/class/dmi/id/product_name)"
echo "Product version:  $(read_file /sys/class/dmi/id/product_version)"
echo "BIOS version:     $(read_file /sys/class/dmi/id/bios_version)"
echo "BIOS date:        $(read_file /sys/class/dmi/id/bios_date)"
echo "Kernel:           $(uname -r)"
echo "Command line:     $(cat /proc/cmdline)"
echo

echo "## Graphics"
if command -v lspci >/dev/null 2>&1; then
  lspci -nnk | awk '
    /VGA compatible controller|3D controller|Display controller/ {print; show=1; next}
    show && /Kernel driver in use|Kernel modules/ {print}
    show && /^$/ {show=0}
  '
else
  echo "lspci not available"
fi
echo

echo "## Backlight devices"
if compgen -G "/sys/class/backlight/*" >/dev/null; then
  for dev in /sys/class/backlight/*; do
    name="$(basename "$dev")"
    brightness="$(read_file "$dev/brightness")"
    max="$(read_file "$dev/max_brightness")"
    type="$(read_file "$dev/type")"
    echo "$name brightness=$brightness max=$max type=$type"
  done
else
  echo "No backlight devices found"
fi
echo

echo "## omen-backlight configuration"
if [[ -r /etc/omen-backlight/env ]]; then
  cat /etc/omen-backlight/env
else
  echo "/etc/omen-backlight/env not found"
fi
echo

echo "## Installed commands"
for cmd in omen-brightness omen-brightness-step omen-backlight-sync; do
  echo "$cmd:"
  found=0

  for path in \
    "/usr/local/bin/$cmd" \
    "/usr/local/sbin/$cmd" \
    "/usr/bin/$cmd" \
    "/usr/sbin/$cmd"
  do
    if [[ -x "$path" ]]; then
      echo "  - $path"
      found=1
    fi
  done

  if [[ "$found" -eq 0 ]]; then
    echo "  - not installed"
  fi
done
echo

echo "## Helper"
HELPER="/usr/local/libexec/omen-backlight/omen-ec-write"

if [[ -x "$HELPER" ]]; then
  echo "Helper path:      $HELPER"
else
  echo "Helper path:      not installed"
fi

if [[ -r /etc/omen-backlight/env ]]; then
  # shellcheck disable=SC1091
  source /etc/omen-backlight/env
fi

REG="${OMEN_BACKLIGHT_REG:-0xFD400CF5}"

echo "Configured reg:   $REG"

if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  if command -v busybox >/dev/null 2>&1; then
    echo -n "Current EC value: "
    busybox devmem "$REG" 8 2>/dev/null || echo "could not read"
  else
    echo "Current EC value: busybox not available"
  fi
else
  echo "Current EC value: run with sudo to read"
fi
echo

echo "## Service"
systemctl status omen-backlight-sync.service --no-pager 2>/dev/null || echo "Service not found"
echo

echo "## Recent service logs since service start"
SERVICE_START="$(systemctl show omen-backlight-sync.service -p ActiveEnterTimestamp --value 2>/dev/null || true)"

if [[ -n "$SERVICE_START" && "$SERVICE_START" != "n/a" ]]; then
  journalctl -u omen-backlight-sync.service --since "$SERVICE_START" -n 50 --no-pager 2>/dev/null || echo "No service logs found"
else
  journalctl -u omen-backlight-sync.service -b -n 50 --no-pager 2>/dev/null || echo "No service logs found"
fi
echo

echo "## Quick checks"
if [[ -r /etc/omen-backlight/env ]]; then
  # shellcheck disable=SC1091
  source /etc/omen-backlight/env

  if [[ -n "${OMEN_BACKLIGHT_SOURCE:-}" && -e "$OMEN_BACKLIGHT_SOURCE" ]]; then
    echo "Configured source exists: yes"
  else
    echo "Configured source exists: no"
  fi

  echo "Configured register: ${OMEN_BACKLIGHT_REG:-unknown}"
  echo "Custom register enabled: ${OMEN_ALLOW_CUSTOM_REG:-0}"
else
  echo "Config file missing"
fi

echo
echo "# End of report"
